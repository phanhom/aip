{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aip-protocol.dev/schemas/status.schema.json",
  "title": "AIP Status Protocol Schemas",
  "description": "Schemas for the AIP status protocol: AgentStatus, RecursiveStatusNode, GroupStatus, and supporting types.",

  "$defs": {
    "StatusEndpoints": {
      "type": "object",
      "description": "Discoverable endpoints for an agent.",
      "properties": {
        "aip": {
          "type": ["string", "null"],
          "format": "uri",
          "description": "Full URL of the messaging endpoint (e.g., https://agent.example.com/v1/aip)."
        },
        "status": {
          "type": ["string", "null"],
          "format": "uri",
          "description": "Full URL of the status endpoint (e.g., https://agent.example.com/v1/status)."
        }
      },
      "additionalProperties": true
    },

    "Presentation": {
      "type": "object",
      "description": "Human-facing display metadata. Enables dashboards, UIs, and multi-agent platforms to render consistent, localized agent cards without relying on free-form text fields.",
      "properties": {
        "display_name": {
          "type": "string",
          "description": "Short human-readable name for UI display (e.g., \"Backend Engineer\", \"Code Reviewer\"). Distinct from agent_id which is a machine identifier.",
          "examples": ["Backend Engineer", "Risk Analyzer", "Deployment Bot"]
        },
        "tagline": {
          "type": ["string", "null"],
          "description": "One-line summary of what this agent does, suitable for subtitle or tooltip.",
          "maxLength": 140,
          "examples": ["Designs and reviews REST APIs with OpenAPI output"],
          "default": null
        },
        "description": {
          "type": ["string", "null"],
          "description": "Longer human-readable description. Markdown MAY be used.",
          "default": null
        },
        "icon_url": {
          "type": ["string", "null"],
          "format": "uri",
          "description": "URL to an avatar or icon image (SHOULD be square, RECOMMENDED 256×256 minimum).",
          "default": null
        },
        "color": {
          "type": ["string", "null"],
          "pattern": "^#[0-9a-fA-F]{6}$",
          "description": "Brand / accent color as a hex string (e.g., \"#4A90D9\"). UIs MAY use this for badges, borders, or status indicators.",
          "examples": ["#4A90D9", "#34D399", "#F59E0B"],
          "default": null
        },
        "locale": {
          "type": "string",
          "pattern": "^[a-z]{2}(-[A-Z]{2})?$",
          "description": "BCP 47 language tag indicating the locale of all human-readable text in this status response (e.g., \"en\", \"zh-CN\", \"ja\").",
          "default": "en",
          "examples": ["en", "zh-CN", "ja", "ko", "fr"]
        },
        "categories": {
          "type": "array",
          "items": { "type": "string" },
          "description": "UI categorization labels for marketplace-style discovery (e.g., [\"engineering\", \"backend\"]).",
          "default": []
        },
        "homepage_url": {
          "type": ["string", "null"],
          "format": "uri",
          "description": "URL to the agent's documentation or homepage.",
          "default": null
        },
        "privacy_policy_url": {
          "type": ["string", "null"],
          "format": "uri",
          "description": "URL to the agent provider's privacy policy.",
          "default": null
        },
        "tos_url": {
          "type": ["string", "null"],
          "format": "uri",
          "description": "URL to the agent provider's terms of service.",
          "default": null
        },
        "provider": {
          "type": ["object", "null"],
          "description": "Information about the organization or individual that operates this agent.",
          "properties": {
            "name": {
              "type": "string",
              "description": "Provider / organization name."
            },
            "url": {
              "type": ["string", "null"],
              "format": "uri"
            }
          },
          "required": ["name"],
          "default": null
        }
      },
      "required": ["display_name"],
      "additionalProperties": true
    },

    "Skill": {
      "type": "object",
      "description": "Structured skill descriptor for rich agent discovery. Defines what an agent can do, what it expects, and what it produces.",
      "required": ["id", "name", "description"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique skill identifier (e.g., \"api-design\", \"code-review\")."
        },
        "name": {
          "type": "string",
          "description": "Human-readable skill name."
        },
        "description": {
          "type": "string",
          "description": "What this skill does."
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Categorization tags (e.g., [\"backend\", \"api\"]).",
          "default": []
        },
        "input_modes": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Accepted input MIME types.",
          "default": ["application/json"]
        },
        "output_modes": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Produced output MIME types.",
          "default": ["application/json"]
        },
        "input_schema": {
          "oneOf": [
            { "type": "object", "additionalProperties": true },
            { "type": "null" }
          ],
          "description": "JSON Schema describing expected payload structure.",
          "default": null
        },
        "output_schema": {
          "oneOf": [
            { "type": "object", "additionalProperties": true },
            { "type": "null" }
          ],
          "description": "JSON Schema describing output payload structure.",
          "default": null
        },
        "examples": {
          "type": "array",
          "items": { "type": "object" },
          "description": "Example input/output pairs for documentation.",
          "default": []
        }
      },
      "additionalProperties": true
    },

    "AgentAssignment": {
      "type": "object",
      "description": "Platform-assigned identity and constraints. Represents the 'job description' the platform gives an agent, separate from its native profile.",
      "properties": {
        "assigned_role": {
          "type": ["string", "null"],
          "description": "Platform-assigned role (may differ from the agent's self-declared role).",
          "default": null
        },
        "team": {
          "type": ["string", "null"],
          "description": "Team or department this agent belongs to.",
          "default": null
        },
        "scope": {
          "type": ["string", "null"],
          "description": "Human-readable description of the agent's work boundaries.",
          "default": null
        },
        "granted_tools": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Tools or resources the platform grants beyond the agent's native capabilities.",
          "default": []
        },
        "granted_skills": {
          "type": "array",
          "items": { "$ref": "#/$defs/Skill" },
          "description": "Additional skill descriptors the platform injects (merged with native skills for discovery).",
          "default": []
        },
        "constraints": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Boundaries or rules the platform imposes on this agent.",
          "default": []
        },
        "supervisor": {
          "type": ["string", "null"],
          "description": "Agent ID of the assigned supervisor (may override the agent's self-declared superior).",
          "default": null
        },
        "priority": {
          "type": ["string", "null"],
          "description": "Platform-assigned priority level (e.g., \"high\", \"normal\", \"low\").",
          "default": null
        },
        "assigned_at": {
          "type": ["string", "null"],
          "format": "date-time",
          "description": "ISO 8601 timestamp of when the assignment was last updated.",
          "default": null
        },
        "metadata": {
          "type": ["object", "null"],
          "additionalProperties": true,
          "description": "Platform-specific extension fields.",
          "default": null
        }
      },
      "additionalProperties": true
    },

    "AuthenticationInfo": {
      "type": "object",
      "description": "Supported authentication schemes. Enables clients to discover how to authenticate before sending messages.",
      "properties": {
        "schemes": {
          "type": "array",
          "items": {
            "type": "string",
            "examples": ["bearer", "api_key", "oauth2", "mtls"]
          },
          "description": "Supported auth scheme identifiers.",
          "default": []
        },
        "oauth2": {
          "oneOf": [
            {
              "type": "object",
              "properties": {
                "token_url": {
                  "type": "string",
                  "format": "uri",
                  "description": "OAuth2 token endpoint URL."
                },
                "scopes": {
                  "type": "array",
                  "items": { "type": "string" },
                  "description": "Available OAuth2 scopes."
                }
              },
              "required": ["token_url"]
            },
            { "type": "null" }
          ],
          "description": "OAuth2 configuration, if applicable.",
          "default": null
        }
      },
      "additionalProperties": true
    },

    "WorkSnapshot": {
      "type": "object",
      "description": "Work-in-progress snapshot for operational visibility.",
      "properties": {
        "tasks": {
          "type": "array",
          "items": { "type": "object" },
          "description": "Recent task items.",
          "default": []
        },
        "reports": {
          "type": "array",
          "items": { "type": "object" },
          "description": "Recent reports.",
          "default": []
        },
        "recent_messages": {
          "type": "array",
          "items": { "type": "object" },
          "description": "Recent AIP messages.",
          "default": []
        },
        "last_seen": {
          "type": ["string", "null"],
          "format": "date-time",
          "description": "Last activity timestamp."
        },
        "pending_tasks": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of incomplete tasks.",
          "default": 0
        }
      },
      "additionalProperties": true
    },

    "RateLimitInfo": {
      "type": "object",
      "description": "Rate limiting and quota information for client self-regulation.",
      "properties": {
        "max_requests_per_minute": {
          "type": ["integer", "null"],
          "minimum": 0,
          "description": "Maximum POST /v1/aip requests per minute. null = unlimited."
        },
        "max_requests_per_day": {
          "type": ["integer", "null"],
          "minimum": 0,
          "description": "Maximum requests per calendar day (UTC). null = unlimited."
        },
        "max_concurrent_tasks": {
          "type": ["integer", "null"],
          "minimum": 0,
          "description": "Maximum simultaneous tasks in non-terminal state. null = unlimited."
        },
        "remaining_requests": {
          "type": ["integer", "null"],
          "minimum": 0,
          "description": "Remaining requests in the current minute window."
        },
        "remaining_tasks": {
          "type": ["integer", "null"],
          "minimum": 0,
          "description": "Remaining task slots available."
        },
        "reset_at": {
          "type": ["string", "null"],
          "format": "date-time",
          "description": "ISO 8601 UTC timestamp when the rate limit window resets."
        }
      },
      "additionalProperties": true
    },

    "AgentStatus": {
      "type": "object",
      "description": "Status document for a single agent. Combines machine-readable discovery with human-facing presentation.",
      "required": ["agent_id", "role"],
      "properties": {
        "agent_id": {
          "type": "string",
          "description": "Unique machine identifier for this agent."
        },
        "role": {
          "type": "string",
          "description": "Agent's role in the group."
        },
        "namespace": {
          "type": ["string", "null"],
          "description": "Logical namespace for multi-tenant isolation (e.g., \"acme-corp\", \"team-infra\"). Agents in different namespaces are invisible to each other by default.",
          "default": null,
          "examples": ["acme-corp", "team-infra", "prod", "staging"]
        },
        "presentation": {
          "oneOf": [
            { "$ref": "#/$defs/Presentation" },
            { "type": "null" }
          ],
          "description": "Human-facing display metadata for dashboards, agent cards, and marketplace UIs.",
          "default": null
        },
        "superior": {
          "type": ["string", "null"],
          "description": "Agent ID of the direct superior.",
          "default": null
        },
        "authority_weight": {
          "type": ["integer", "null"],
          "minimum": 0,
          "maximum": 100,
          "description": "Agent's authority weight (0-100).",
          "default": null
        },
        "lifecycle": {
          "type": ["string", "null"],
          "enum": ["idle", "starting", "running", "blocked", "degraded", "failed", null],
          "description": "Agent lifecycle state.",
          "default": null
        },
        "port": {
          "type": ["integer", "null"],
          "description": "Service port.",
          "default": null
        },
        "ok": {
          "type": "boolean",
          "description": "Whether the agent is healthy.",
          "default": true
        },
        "base_url": {
          "type": ["string", "null"],
          "format": "uri",
          "description": "Agent's base URL for discovery.",
          "default": null
        },
        "endpoints": {
          "oneOf": [
            { "$ref": "#/$defs/StatusEndpoints" },
            { "type": "null" }
          ],
          "description": "Discoverable endpoints.",
          "default": null
        },
        "capabilities": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of supported action names (simple discovery).",
          "default": []
        },
        "skills": {
          "type": "array",
          "items": { "$ref": "#/$defs/Skill" },
          "description": "Structured skill descriptors with input/output schemas (rich discovery).",
          "default": []
        },
        "supported_versions": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Protocol versions this agent supports.",
          "default": ["1.0"]
        },
        "authentication": {
          "oneOf": [
            { "$ref": "#/$defs/AuthenticationInfo" },
            { "type": "null" }
          ],
          "description": "Supported authentication schemes.",
          "default": null
        },
        "rate_limits": {
          "oneOf": [
            { "$ref": "#/$defs/RateLimitInfo" },
            { "type": "null" }
          ],
          "description": "Rate limiting and quota information.",
          "default": null
        },
        "pending_tasks": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of pending tasks.",
          "default": 0
        },
        "recent_errors": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of recent errors.",
          "default": 0
        },
        "waiting_for_approval": {
          "type": "boolean",
          "description": "Whether the agent is blocked on approval.",
          "default": false
        },
        "last_message_at": {
          "type": ["string", "null"],
          "format": "date-time",
          "description": "ISO 8601 timestamp of last AIP message.",
          "default": null
        },
        "last_seen_at": {
          "type": ["string", "null"],
          "format": "date-time",
          "description": "ISO 8601 timestamp of last activity.",
          "default": null
        },
        "metadata": {
          "type": ["object", "null"],
          "description": "Implementation-specific metadata.",
          "additionalProperties": true,
          "default": null
        },
        "assignment": {
          "oneOf": [
            { "$ref": "#/$defs/AgentAssignment" },
            { "type": "null" }
          ],
          "description": "Platform-assigned role, scope, and constraints (see Section 5.12). Null if the agent has no platform assignment.",
          "default": null
        },
        "work": {
          "oneOf": [
            { "$ref": "#/$defs/WorkSnapshot" },
            { "type": "null" }
          ],
          "description": "Work-in-progress snapshot.",
          "default": null
        }
      },
      "additionalProperties": true
    },

    "RecursiveStatusNode": {
      "type": "object",
      "description": "Recursive status tree: agent plus all subordinates.",
      "required": ["self"],
      "properties": {
        "self": {
          "$ref": "#/$defs/AgentStatus"
        },
        "subordinates": {
          "type": "array",
          "items": { "$ref": "#/$defs/RecursiveStatusNode" },
          "default": []
        }
      },
      "additionalProperties": false
    },

    "GroupStatus": {
      "type": "object",
      "description": "Flat group-wide status document for dashboards and monitoring.",
      "required": ["ok", "root_agent_id", "agents"],
      "properties": {
        "ok": {
          "type": "boolean",
          "description": "Overall group health."
        },
        "service": {
          "type": "string",
          "description": "Service identifier.",
          "default": "aip"
        },
        "namespace": {
          "type": ["string", "null"],
          "description": "Namespace of this agent group.",
          "default": null
        },
        "root_agent_id": {
          "type": "string",
          "description": "Root coordinator agent ID."
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 generation timestamp."
        },
        "topology": {
          "type": "object",
          "description": "Map of agent_id to list of direct subordinate IDs.",
          "additionalProperties": {
            "type": "array",
            "items": { "type": "string" }
          },
          "default": {}
        },
        "waiting_for_approval": {
          "type": "boolean",
          "description": "Whether any agent is blocked on approval.",
          "default": false
        },
        "agents": {
          "type": "array",
          "items": { "$ref": "#/$defs/AgentStatus" },
          "description": "Flat list of all agent statuses."
        }
      },
      "additionalProperties": true
    }
  },

  "oneOf": [
    { "$ref": "#/$defs/AgentStatus" },
    { "$ref": "#/$defs/RecursiveStatusNode" },
    { "$ref": "#/$defs/GroupStatus" }
  ]
}
